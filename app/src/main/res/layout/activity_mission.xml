<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Mission header -->
    <TextView
        android:id="@+id/tvMissionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MISSION"
        android:textSize="18sp" android:textStyle="bold"
        android:textColor="@color/accent_cyan"
        android:gravity="center"
        android:padding="16dp"/>

    <!-- Combat status panel -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Crew A row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:id="@+id/tvCrewAName"
                    android:layout_width="90dp" android:layout_height="wrap_content"
                    android:text="Crew A" android:textColor="@color/text_primary"
                    android:textSize="12sp" android:textStyle="bold"/>
                <ProgressBar android:id="@+id/pbCrewAEnergy"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="16dp"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:max="20" android:progress="20"
                    android:progressTint="@color/pilot_blue"
                    android:progressBackgroundTint="@color/divider"/>
                <TextView android:id="@+id/tvCrewAEnergy"
                    android:layout_width="50dp" android:layout_height="wrap_content"
                    android:text="20/20" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:gravity="end"/>
            </LinearLayout>

            <!-- Crew B row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:id="@+id/tvCrewBName"
                    android:layout_width="90dp" android:layout_height="wrap_content"
                    android:text="Crew B" android:textColor="@color/text_primary"
                    android:textSize="12sp" android:textStyle="bold"/>
                <ProgressBar android:id="@+id/pbCrewBEnergy"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="16dp"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:max="20" android:progress="20"
                    android:progressTint="@color/soldier_red"
                    android:progressBackgroundTint="@color/divider"/>
                <TextView android:id="@+id/tvCrewBEnergy"
                    android:layout_width="50dp" android:layout_height="wrap_content"
                    android:text="20/20" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:gravity="end"/>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginBottom="8dp"/>

            <!-- Threat row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tvThreatName"
                    android:layout_width="90dp" android:layout_height="wrap_content"
                    android:text="Threat" android:textColor="@color/soldier_red"
                    android:textSize="12sp" android:textStyle="bold"/>
                <ProgressBar android:id="@+id/pbThreatEnergy"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="16dp"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:max="25" android:progress="25"
                    android:progressTint="@color/soldier_red"
                    android:progressBackgroundTint="@color/divider"/>
                <TextView android:id="@+id/tvThreatEnergy"
                    android:layout_width="50dp" android:layout_height="wrap_content"
                    android:text="25/25" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:gravity="end"/>
            </LinearLayout>

            <!-- Threat status -->
            <TextView android:id="@+id/tvThreatStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="ACTIVE" android:textColor="@color/soldier_red"
                android:textSize="11sp" android:gravity="end"
                android:paddingTop="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Mission log -->
    <ScrollView android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/tvMissionLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="@color/card_bg"/>
    </ScrollView>

    <!-- Tactical action buttons -->
    <LinearLayout android:id="@+id/layoutTactical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <Button android:id="@+id/btnAttack"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="ATTACK"
            android:backgroundTint="@color/soldier_red"
            android:textColor="@color/text_primary"
            android:textSize="13sp" android:textStyle="bold"/>

        <Button android:id="@+id/btnDefend"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="DEFEND"
            android:backgroundTint="@color/pilot_blue"
            android:textColor="@color/text_primary"
            android:textSize="13sp" android:textStyle="bold"/>

        <Button android:id="@+id/btnHeal"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1"
            android:text="HEAL"
            android:backgroundTint="@color/medic_green"
            android:textColor="@color/bg_dark"
            android:textSize="13sp" android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Finish button shown at end -->
    <Button android:id="@+id/btnFinish"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:text="FINISH MISSION"
        android:backgroundTint="@color/accent_cyan"
        android:textColor="@color/bg_dark"
        android:textStyle="bold"
        android:visibility="gone"/>

</LinearLayout>
