<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MISSION CONTROL"
        android:textSize="22sp" android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:padding="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select 2 crew members and choose mission type"
        android:textColor="@color/text_secondary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp"/>

    <!-- Mission type spinner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mission: "
            android:textColor="@color/text_secondary"/>

        <Spinner
            android:id="@+id/spinnerMissionType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/accent_cyan"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCrew"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button android:id="@+id/btnLaunchMission"
            android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:layout_marginEnd="8dp"
            android:text="LAUNCH MISSION"
            android:backgroundTint="@color/soldier_red"
            android:textColor="@color/text_primary" android:textStyle="bold"/>

        <Button android:id="@+id/btnReturnToQuarters"
            android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Quarters"
            android:backgroundTint="@color/card_bg"
            android:textColor="@color/text_primary"/>
    </LinearLayout>
</LinearLayout>
