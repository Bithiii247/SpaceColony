<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SIMULATOR"
        android:textSize="22sp" android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:padding="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select crew to train (+1 XP to +1 Skill)"
        android:textColor="@color/text_secondary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCrew"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button android:id="@+id/btnTrain"
            android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:layout_marginEnd="8dp"
            android:text="TRAIN SELECTED"
            android:backgroundTint="@color/engineer_yellow"
            android:textColor="@color/bg_dark" android:textStyle="bold"/>

        <Button android:id="@+id/btnToQuarters"
            android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Quarters"
            android:backgroundTint="@color/card_bg"
            android:textColor="@color/text_primary"/>
    </LinearLayout>
</LinearLayout>
